# YOLO_MODEL=yolov8n.pt
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# WHISPER_MODEL_SIZE=tiny
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# VIDEO_FRAME_SAMPLES=8
# BM25_TOP_K=50
