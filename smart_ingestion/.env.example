# smart_ingestion — environment configuration
# Copy this to .env and fill in your values.

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Model tuning (defaults are already optimised — only change if needed) ─────
